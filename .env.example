# ==========================================================
# 🌐 CONFIGURACIÓN DE RED Y DOMINIO
# ==========================================================
# Puertos locales donde escuchará Jitsi (útil si tienes otros servicios en el VPS)
HTTP_PORT=8181
HTTPS_PORT=8443

# URL pública (IMPORTANTE: Debe ser el dominio real, sin / al final)
PUBLIC_URL=https://jitsi.ejemplo.com

# ==========================================================
# 🔒 CERTIFICADOS SSL (LET'S ENCRYPT)
# ==========================================================
# 1 para activar generación automática, 0 para usar certificados propios
ENABLE_LETSENCRYPT=1
LETSENCRYPT_DOMAIN=jitsi.ejemplo.com
LETSENCRYPT_EMAIL=admin@ejemplo.com

# ==========================================================
# 📹 CONFIGURACIÓN DE JIBRI (STREAMING Y GRABACIÓN)
# ==========================================================
DISPLAY=:0
ENABLE_RECORDING=1
ENABLE_LIVESTREAMING=1

# Usuario "bot" que entra a la sala para grabar (Domino: recorder.meet.jitsi)
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=password_seguro_recorder

# Usuario para que Jibri se autentique en el sistema (Dominio: auth.meet.jitsi)
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=password_seguro_jibri
JIBRI_XMPP_USER_DOMAIN=auth.meet.jitsi

# Sala de control interna para Jibri
JIBRI_BREWERY_MUC=jibritests
JIBRI_PENDING_TIMEOUT=90
JIBRI_USAGE_TIMEOUT=0
JIBRI_SKIP_ALSA_CHECK=1

# Configuración de Audio Virtual (Necesita el módulo snd-aloop en el host)
JIBRI_FFMPEG_AUDIO_SOURCE=alsa
JIBRI_FFMPEG_AUDIO_DEVICE=plug:dummy

# 🚀 BANDERAS DE CHROMIUM (EL "ZOOM" Y MODO KIOSKO)
# --kiosk: Quita barras de navegación.
# --force-device-scale-factor: Aplica el zoom digital (1.1 = 110%).
# --window-size: Ajusta la resolución de captura.
JIBRI_CHROMIUM_FLAGS="--no-sandbox --disable-dev-shm-usage --ignore-certificate-errors --allow-insecure-localhost --allow-running-insecure-content --autoplay-policy=no-user-gesture-required --use-fake-ui-for-media-stream --use-fake-device-for-media-stream --kiosk --window-size=1280,720 --window-position=0,0 --force-device-scale-factor=1.1 --high-dpi-support=1 --force-dark-mode"

# ==========================================================
# 🔐 SEGURIDAD Y COMUNICACIÓN INTERNA (SECRETOS)
# ==========================================================
# Cambia estas claves por strings aleatorios largos
JICOFO_COMPONENT_SECRET=clave_secreta_jicofo
JICOFO_AUTH_PASSWORD=clave_auth_jicofo
JVB_AUTH_PASSWORD=clave_auth_jvb
JIGASI_XMPP_PASSWORD=clave_auth_jigasi
JIBRI_AUTH_PASSWORD=clave_auth_jibri

# ==========================================================
# 🏗️ DOMINIOS INTERNOS XMPP (INTERNAL ONLY)
# ==========================================================
# Estos valores suelen dejarse por defecto, pero son vitales para Prosody
XMPP_SERVER=prosody
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi

# Lista de dominios que Prosody debe habilitar (separados por coma)
XMPP_EXTRA_DOMAINS=auth.meet.jitsi,recorder.meet.jitsi,muc.meet.jitsi,internal-muc.meet.jitsi