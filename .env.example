# ==========================================================
# CONFIGURACIÓN GENERAL DE RED
# ==========================================================
# Puertos en los que escuchará el contenedor Web (Nginx)
HTTP_PORT=8181
HTTPS_PORT=8443

# URL pública de tu instancia (IMPORTANTE: Sin barra diagonal al final)
PUBLIC_URL=https://jitsi.tudominio.com

# ==========================================================
# CERTIFICADOS SSL (LET'S ENCRYPT)
# ==========================================================
# Cambia a 1 para generar certificados automáticamente
ENABLE_LETSENCRYPT=1
LETSENCRYPT_DOMAIN=jitsi.tudominio.com
LETSENCRYPT_EMAIL=tu-correo@ejemplo.com

# ==========================================================
# CONFIGURACIÓN DE JIBRI (GRABACIÓN Y STREAMING)
# ==========================================================
# Habilitar las funcionalidades de grabación y vivo
ENABLE_RECORDING=1
ENABLE_LIVESTREAMING=1

# Usuario interno que Jibri usará para entrar a la sala (Default: recorder)
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=password_seguro_aqui

# Usuario para el control de Jibri vía XMPP (Default: jibri)
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=password_seguro_jibri

# Flags de Chromium para Jibri
# NOTA: --kiosk fuerza el modo pantalla completa (zoom) para ocultar la interfaz del navegador
JIBRI_CHROMIUM_FLAGS="--no-sandbox --disable-dev-shm-usage --ignore-certificate-errors --allow-insecure-localhost --allow-running-insecure-content --autoplay-policy=no-user-gesture-required --use-fake-ui-for-media-stream --use-fake-device-for-media-stream --kiosk"

# Configuración técnica de Audio (Loopback virtual)
JIBRI_FFMPEG_AUDIO_SOURCE=alsa
JIBRI_FFMPEG_AUDIO_DEVICE=plug:dummy

# ==========================================================
# SEGURIDAD Y CONTRASEÑAS INTERNAS
# ==========================================================
# Estas claves son para la comunicación entre contenedores (Web, Jicofo, JVB)
JICOFO_COMPONENT_SECRET=clave_jicofo_secreta
JICOFO_AUTH_PASSWORD=clave_auth_jicofo
JVB_AUTH_PASSWORD=clave_auth_jvb
JIGASI_XMPP_PASSWORD=clave_auth_jigasi
JIBRI_AUTH_PASSWORD=clave_auth_jibri

# ==========================================================
# DOMINIOS INTERNOS XMPP (CONFIGURACIÓN AVANZADA)
# ==========================================================
# No cambiar a menos que sepas qué estás haciendo
XMPP_SERVER=prosody
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_EXTRA_DOMAINS=auth.meet.jitsi,recorder.meet.jitsi,muc.meet.jitsi,internal-muc.meet.jitsi